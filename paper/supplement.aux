\newlabel{tab:supp-classical-24}{{6}{4}{FD-pure (repulsion + boundary, no mask) and FD+spring (\,+\,degree-normalised net-spring weight $1.0$) compared to VSR-post($\lambda {=}8$) on the same $6$ circuits $\times $ $4$ seeds as Table~1. Replaces the earlier $15$-draft cached evaluation}{table.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Classifier-guidance ($w\in \{2,8\}$, the two best per-circuit legality weights) and RePaint ($t_\text  {start}\in \{0.3, 0.5\}$, the two best $t_\text  {start}$) at all $4$ seeds. Replaces the earlier seed-$42$-only sweep on this slice.}}{4}{table.7}\protected@file@percent }
\newlabel{tab:supp-baseline-sweeps-24}{{7}{4}{Classifier-guidance ($w\in \{2,8\}$, the two best per-circuit legality weights) and RePaint ($t_\text {start}\in \{0.3, 0.5\}$, the two best $t_\text {start}$) at all $4$ seeds. Replaces the earlier seed-$42$-only sweep on this slice}{table.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces LOCO cross-validation for $\lambda $ selection on the $\lambda $-sweep results. $\hat  \lambda $ is chosen on the 5 held-in circuits (objective: strict-Pareto count, tie-break smaller $\lambda $); $\Delta v$ and $\Delta h$ are evaluated on the held-out circuit. ``Oracle $\lambda ^\star $'' is the per-circuit best $\lambda $ that minimises $\Delta h$ subject to $\Delta v < 0$. All 6 folds select $\hat  \lambda {=}8$, and held-out test gives \textbf  {$6/6$ strict-Pareto improvement} matching the per-circuit oracle. This is the principled selection rule. Raw rows: \texttt  {results/vsr\_extra/lambda\_loco.csv}.}}{4}{table.8}\protected@file@percent }
\newlabel{tab:supp-lambda-loco}{{8}{4}{LOCO cross-validation for $\lambda $ selection on the $\lambda $-sweep results. $\hat \lambda $ is chosen on the 5 held-in circuits (objective: strict-Pareto count, tie-break smaller $\lambda $); $\Delta v$ and $\Delta h$ are evaluated on the held-out circuit. ``Oracle $\lambda ^\star $'' is the per-circuit best $\lambda $ that minimises $\Delta h$ subject to $\Delta v < 0$. All 6 folds select $\hat \lambda {=}8$, and held-out test gives \textbf {$6/6$ strict-Pareto improvement} matching the per-circuit oracle. This is the principled selection rule. Raw rows: \texttt {results/vsr\_extra/lambda\_loco.csv}}{table.8}{}}
\@writefile{toc}{\contentsline {section}{\numberline {G}Independent classical force-directed legalizer}{4}{appendix.G}\protected@file@percent }
\newlabel{sec:supp-classical}{{G}{4}{Independent classical force-directed legalizer}{appendix.G}{}}
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces Independent classical force-directed legalizer baselines vs.\ VSR-post on cached ChipDiffusion drafts. FD-pure and FD+spring use the same step-budget and step-size as VSR-post and operate on \emph  {all} macros (no mask). All three reduce violations comparably; VSR-post's HPWL preservation advantage comes from the selector mask + tunable $\lambda $, not from a different force model. Raw rows: \texttt  {results/vsr\_extra/classical\_legalizer.json}.}}{5}{table.9}\protected@file@percent }
\newlabel{tab:supp-classical}{{9}{5}{Independent classical force-directed legalizer baselines vs.\^^MVSR-post on cached ChipDiffusion drafts. FD-pure and FD+spring use the same step-budget and step-size as VSR-post and operate on \emph {all} macros (no mask). All three reduce violations comparably; VSR-post's HPWL preservation advantage comes from the selector mask + tunable $\lambda $, not from a different force model. Raw rows: \texttt {results/vsr\_extra/classical\_legalizer.json}}{table.9}{}}
\@writefile{toc}{\contentsline {section}{\numberline {H}Tuned baselines: sweeps of cg legality weight and RePaint $t_\text  {start}$}{5}{appendix.H}\protected@file@percent }
\newlabel{sec:supp-tuned-baselines}{{H}{5}{Tuned baselines: sweeps of cg legality weight and RePaint $t_\text {start}$}{appendix.H}{}}
\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces Best-tuned cg and RePaint vs. VSR-post per circuit. $w^\star $ and $t^\star $ are the legality weight / $t_\text  {start}$ that minimise violation count for that family on that circuit. Across all 6 circuits, VSR-post produces a strictly larger (more negative) $\Delta v\,\%$ than either tuned baseline. Cross-circuit median: cg-tuned reduces violations by only $7\%$ at the cost of $+14\%$ HPWL; RePaint-tuned \emph  {increases} violations by $109\%$ (because the small $t_\text  {start}$ that best preserves wirelength produces collapsed, heavily-overlapping placements); VSR-post simultaneously reduces violations by $55\%$ and HPWL by $11\%$. Raw rows: \texttt  {results/vsr\_extra/baseline\_sweeps.json}.}}{5}{table.10}\protected@file@percent }
\newlabel{tab:supp-tuned-baselines}{{10}{5}{Best-tuned cg and RePaint vs. VSR-post per circuit. $w^\star $ and $t^\star $ are the legality weight / $t_\text {start}$ that minimise violation count for that family on that circuit. Across all 6 circuits, VSR-post produces a strictly larger (more negative) $\Delta v\,\%$ than either tuned baseline. Cross-circuit median: cg-tuned reduces violations by only $7\%$ at the cost of $+14\%$ HPWL; RePaint-tuned \emph {increases} violations by $109\%$ (because the small $t_\text {start}$ that best preserves wirelength produces collapsed, heavily-overlapping placements); VSR-post simultaneously reduces violations by $55\%$ and HPWL by $11\%$. Raw rows: \texttt {results/vsr\_extra/baseline\_sweeps.json}}{table.10}{}}
\@writefile{toc}{\contentsline {section}{\numberline {I}Full-design HPWL with cells fixed at \texttt  {.pl} positions}{6}{appendix.I}\protected@file@percent }
\newlabel{sec:supp-full-hpwl}{{I}{6}{Full-design HPWL with cells fixed at \texttt {.pl} positions}{appendix.I}{}}
\@writefile{lot}{\contentsline {table}{\numberline {11}{\ignorespaces Full per-trial metrics across 24 (circuit, seed) trials, $\lambda {=}2$ post-VSR. $\Delta \text  {oa}\,\%$ is the change in total overlap area $\DOTSB \sum@ \slimits@ _{ij} A_{ij}/2$ (a continuous quantity sensitive to near-misses, in addition to the integer violation count). $\Delta h_\text  {macro}\,\%$ is the macros-only HPWL (matches main-paper Table~1). $\Delta h_\text  {full}\,\%$ is the full-design HPWL with cells held at \texttt  {.pl} positions. Two findings: (i) the full-design HPWL median ($+10.7\%$) is comparable to the macros-only median ($+8.7\%$), so the macro-axis HPWL trend generalises to the full design on most circuits; (ii) on adaptec2 the full-design HPWL is $-31\%$ (macros-only is $+9\%$), suggesting that VSR's repair on adaptec2 moves macros into positions that better match the cell distribution; (iii) on adaptec3 the full-design HPWL inflates more sharply than macros-only (consistent with adaptec3 having dense local cell-macro coupling that VSR does not reason about). VSR-intra-soft is HPWL-neutral on the full design (median $-1.6\%$). Raw rows: \texttt  {results/vsr\_extra/full\_metrics.json}.}}{6}{table.11}\protected@file@percent }
\newlabel{tab:supp-full-hpwl}{{11}{6}{Full per-trial metrics across 24 (circuit, seed) trials, $\lambda {=}2$ post-VSR. $\Delta \text {oa}\,\%$ is the change in total overlap area $\sum _{ij} A_{ij}/2$ (a continuous quantity sensitive to near-misses, in addition to the integer violation count). $\Delta h_\text {macro}\,\%$ is the macros-only HPWL (matches main-paper Table~1). $\Delta h_\text {full}\,\%$ is the full-design HPWL with cells held at \texttt {.pl} positions. Two findings: (i) the full-design HPWL median ($+10.7\%$) is comparable to the macros-only median ($+8.7\%$), so the macro-axis HPWL trend generalises to the full design on most circuits; (ii) on adaptec2 the full-design HPWL is $-31\%$ (macros-only is $+9\%$), suggesting that VSR's repair on adaptec2 moves macros into positions that better match the cell distribution; (iii) on adaptec3 the full-design HPWL inflates more sharply than macros-only (consistent with adaptec3 having dense local cell-macro coupling that VSR does not reason about). VSR-intra-soft is HPWL-neutral on the full design (median $-1.6\%$). Raw rows: \texttt {results/vsr\_extra/full\_metrics.json}}{table.11}{}}
\@writefile{toc}{\contentsline {section}{\numberline {J}Toy cross-domain experiment}{6}{appendix.J}\protected@file@percent }
\newlabel{sec:supp-toy2d}{{J}{6}{Toy cross-domain experiment}{appendix.J}{}}
\@writefile{lot}{\contentsline {table}{\numberline {12}{\ignorespaces Toy 2D non-overlap, mean over $250$ runs/method. Two observations: (i) classifier guidance with strong constraint weighting kills overlap but inflates wirelength $5.4\times $, mirroring the placement-domain finding; (ii) RePaint with binary mask minimizes pair count but produces residual small overlaps; VSR-post minimizes the total overlap area while preserving wirelength. Raw rows: \texttt  {results/toy/toy\_results.json}.}}{6}{table.12}\protected@file@percent }
\newlabel{tab:supp-toy}{{12}{6}{Toy 2D non-overlap, mean over $250$ runs/method. Two observations: (i) classifier guidance with strong constraint weighting kills overlap but inflates wirelength $5.4\times $, mirroring the placement-domain finding; (ii) RePaint with binary mask minimizes pair count but produces residual small overlaps; VSR-post minimizes the total overlap area while preserving wirelength. Raw rows: \texttt {results/toy/toy\_results.json}}{table.12}{}}
