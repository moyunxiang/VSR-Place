\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Main results on ISPD2005 at $\lambda =2$, averaged over 3 seeds. Negative $\Delta $viol.\% means fewer violations; negative $\Delta $HPWL\% means shorter wirelength.\relax }}{5}{table.caption.20}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{tab:main}{{1}{5}{Main results on ISPD2005 at $\lambda =2$, averaged over 3 seeds. Negative $\Delta $viol.\% means fewer violations; negative $\Delta $HPWL\% means shorter wirelength.\relax }{table.caption.20}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Head-to-head with ChipDiffusion's legalizer}{5}{subsection.4.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces VSR ($\lambda =2$, 100 steps) vs.\ both ChipDiffusion legalizer configs (5000-step SGD), averaged over 3 seeds. $\Delta $v\% = violation reduction (negative = fewer violations; lower is better). $\Delta $h\% = HPWL change (negative = shorter wirelength; lower is better). VSR wins on every circuit for both metrics against both CD configs. Note the \emph  {scheduled} config's nominal HPWL awareness ($w_{\text  {hpwl}}{=}4{\times }10^{-5}$) is too weak to counter the legality force and in practice \emph  {increases} HPWL more than the standard config.\relax }}{5}{table.caption.21}\protected@file@percent }
\newlabel{tab:cdleg}{{2}{5}{VSR ($\lambda =2$, 100 steps) vs.\ both ChipDiffusion legalizer configs (5000-step SGD), averaged over 3 seeds. $\Delta $v\% = violation reduction (negative = fewer violations; lower is better). $\Delta $h\% = HPWL change (negative = shorter wirelength; lower is better). VSR wins on every circuit for both metrics against both CD configs. Note the \emph {scheduled} config's nominal HPWL awareness ($w_{\text {hpwl}}{=}4{\times }10^{-5}$) is too weak to counter the legality force and in practice \emph {increases} HPWL more than the standard config.\relax }{table.caption.21}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}Intra-sampling VSR (RePaint-style)}{5}{subsection.4.4}\protected@file@percent }
\newlabel{sec:intra}{{4.4}{5}{Intra-sampling VSR (RePaint-style)}{subsection.4.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Post-processing VSR vs.\ intra-sampling VSR, 3-seed means. Intra-sampling trades $2.5$\,pp of violation reduction for $5.5$\,pp of HPWL improvement on average, with its largest gain on bigblue3 ($-43.4$\,pp HPWL). Intra-sampling is also 2--5$\times $ faster because re-denoising uses the diffusion timestep schedule instead of 100 explicit repair steps.\relax }}{6}{table.caption.22}\protected@file@percent }
\newlabel{tab:intra}{{3}{6}{Post-processing VSR vs.\ intra-sampling VSR, 3-seed means. Intra-sampling trades $2.5$\,pp of violation reduction for $5.5$\,pp of HPWL improvement on average, with its largest gain on bigblue3 ($-43.4$\,pp HPWL). Intra-sampling is also 2--5$\times $ faster because re-denoising uses the diffusion timestep schedule instead of 100 explicit repair steps.\relax }{table.caption.22}{}}
