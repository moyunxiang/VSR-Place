\@writefile{toc}{\contentsline {section}{\numberline {P}Iterative VSR + legalizer alternation (Q4): does the method plateau?}{17}{appendix.P}\protected@file@percent }
\newlabel{sec:supp-iterative}{{P}{17}{Iterative VSR + legalizer alternation (Q4): does the method plateau?}{appendix.P}{}}
\@writefile{lot}{\contentsline {table}{\numberline {17}{\ignorespaces Iterative VSR / cd-sched alternation, $24$ trials. \textbf  {The two operators are antagonistic:} a VSR pass cuts $v_\text  {post}$ by another $\sim 8$k, then the next cd-sched pass restores roughly the same amount. Iteration oscillates between two basins of attraction ($\sim 17$k after VSR, $\sim 24$k after cd-sched) rather than plateauing at zero. The lowest $v_\text  {post}$ achievable is $\sim 17$k after the first VSR step --- additional iteration does not help, because cd-sched re-places macros to satisfy density constraints that conflict with VSR's overlap reduction. The remaining $\sim 17$k overlaps appear structural for these benchmarks.}}{17}{table.caption.55}\protected@file@percent }
\newlabel{tab:supp-iterative}{{17}{17}{Iterative VSR / cd-sched alternation, $24$ trials. \textbf {The two operators are antagonistic:} a VSR pass cuts $v_\text {post}$ by another $\sim 8$k, then the next cd-sched pass restores roughly the same amount. Iteration oscillates between two basins of attraction ($\sim 17$k after VSR, $\sim 24$k after cd-sched) rather than plateauing at zero. The lowest $v_\text {post}$ achievable is $\sim 17$k after the first VSR step --- additional iteration does not help, because cd-sched re-places macros to satisfy density constraints that conflict with VSR's overlap reduction. The remaining $\sim 17$k overlaps appear structural for these benchmarks}{table.caption.55}{}}
