\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Circuit-level paired Wilcoxon, $n{=}6$. $^{\star }$: raw $p<0.05$. ``BH-adj.'' is Benjamini--Hochberg FDR adjusted \emph  {per metric column} ($m{=}8$ tests within $\Delta v$ and $m{=}8$ within $\Delta h$, applied independently; $16$ p-values total). ``Bonferroni'' is the very conservative family-wise control with the same per-column $m{=}8$. Under BH, VSR-post outperforms both CD legalizers on both metrics; under Bonferroni nothing reaches $p_\text  {Bonf}{<}0.05$ on $n{=}6$. The seed-level $n{=}24$ table is in the supplement (Table~\ref {tab:wilcoxon-seed}).}}{7}{table.caption.24}\protected@file@percent }
\newlabel{tab:wilcoxon}{{3}{7}{Circuit-level paired Wilcoxon, $n{=}6$. $^{\star }$: raw $p<0.05$. ``BH-adj.'' is Benjamini--Hochberg FDR adjusted \emph {per metric column} ($m{=}8$ tests within $\Delta v$ and $m{=}8$ within $\Delta h$, applied independently; $16$ p-values total). ``Bonferroni'' is the very conservative family-wise control with the same per-column $m{=}8$. Under BH, VSR-post outperforms both CD legalizers on both metrics; under Bonferroni nothing reaches $p_\text {Bonf}{<}0.05$ on $n{=}6$. The seed-level $n{=}24$ table is in the supplement (Table~\ref {tab:wilcoxon-seed})}{table.caption.24}{}}
