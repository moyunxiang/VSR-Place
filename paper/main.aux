\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces VSR pipeline: a verifier produces structured feedback (per-macro severity scalar, pairwise overlap graph, boundary vector) --- piecewise differentiable, but with vanishing gradients in inactive regions; a selector turns it into a soft mask; a 100-step force integrator (post-mode) or structured RePaint (intra-mode) updates only offending macros. Output is a \emph  {repaired} placement (residual violations remain on these benchmarks; see Limitations). No backbone retraining.}}{2}{figure.caption.5}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:framework}{{1}{2}{VSR pipeline: a verifier produces structured feedback (per-macro severity scalar, pairwise overlap graph, boundary vector) --- piecewise differentiable, but with vanishing gradients in inactive regions; a selector turns it into a soft mask; a 100-step force integrator (post-mode) or structured RePaint (intra-mode) updates only offending macros. Output is a \emph {repaired} placement (residual violations remain on these benchmarks; see Limitations). No backbone retraining}{figure.caption.5}{}}
