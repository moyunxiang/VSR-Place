\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Per-circuit, per-method comparison (4 seeds each). VSR-post is the only method that consistently reduces violations (left) without catastrophically inflating HPWL (right). CD-std and CD-sched reduce violations less and balloon HPWL by 70--400\%.}}{6}{figure.caption.22}\protected@file@percent }
\newlabel{fig:percircuit}{{2}{6}{Per-circuit, per-method comparison (4 seeds each). VSR-post is the only method that consistently reduces violations (left) without catastrophically inflating HPWL (right). CD-std and CD-sched reduce violations less and balloon HPWL by 70--400\%}{figure.caption.22}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Number of (circuit, seed) pairs strictly Pareto-improving the raw diffusion draft (\,$\Delta v<0$ AND $\Delta h<0$ jointly) at $\lambda =2$. The complementary $24-12=12$ trials are exactly the ``non-Pareto'' (HPWL-inflation) failures; Appendix~D additionally flags $2$ \emph  {weak-violation-cut} trials on bigblue1 (HPWL improved strongly but $\Delta v > -20\%$), giving the $14$ diagnostic entries. ChipDiffusion's released legalizers achieve $0/24$ strict-Pareto improvements (every trial inflates HPWL). At $\lambda =8$ VSR-post reaches $18/18$ on the lambda-sweep ($n=3$ seeds; full $4$-seed $\lambda {=}8$ result in \S  \ref {sec:downstream_pipeline}).}}{6}{table.caption.23}\protected@file@percent }
\newlabel{tab:strict_pareto}{{2}{6}{Number of (circuit, seed) pairs strictly Pareto-improving the raw diffusion draft (\,$\Delta v<0$ AND $\Delta h<0$ jointly) at $\lambda =2$. The complementary $24-12=12$ trials are exactly the ``non-Pareto'' (HPWL-inflation) failures; Appendix~D additionally flags $2$ \emph {weak-violation-cut} trials on bigblue1 (HPWL improved strongly but $\Delta v > -20\%$), giving the $14$ diagnostic entries. ChipDiffusion's released legalizers achieve $0/24$ strict-Pareto improvements (every trial inflates HPWL). At $\lambda =8$ VSR-post reaches $18/18$ on the lambda-sweep ($n=3$ seeds; full $4$-seed $\lambda {=}8$ result in \S \ref {sec:downstream_pipeline})}{table.caption.23}{}}
