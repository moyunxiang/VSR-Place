\@writefile{toc}{\contentsline {section}{\numberline {M}External legalizer pipeline: DREAMPlace}{16}{appendix.M}\protected@file@percent }
\newlabel{sec:supp-dreamplace}{{M}{16}{External legalizer pipeline: DREAMPlace}{appendix.M}{}}
\@writefile{lot}{\contentsline {table}{\numberline {14}{\ignorespaces External legalizer pipeline. All $24$ trials, $7$ pre-conditioners. All force-directed pre-conditioners (FD-pure, FD+spring, VSR-post at every $\lambda $) halve the median residual relative to raw ($\sim 9.5$--$10.4$k vs.\ $20$k); VSR-intra-soft does not help ($\sim 20$k, $p_v{=}1.0$ vs.\ raw). Among force-directed pre-conditioners, none is significantly better than another (VSR$_{\lambda =8}$ vs.\ FD-pure $p_v{=}0.22$). \textbf  {Full legality is $0/24$ under every pre-conditioner}; $\mathbf  {0/168}$ method-trials ever reach $v{=}0$. Macros-only HPWL is not comparable post-DREAMPlace (DREAMPlace optimises full-design density+wirelength on its own objective).}}{16}{table.caption.52}\protected@file@percent }
\newlabel{tab:supp-dp-pipeline}{{14}{16}{External legalizer pipeline. All $24$ trials, $7$ pre-conditioners. All force-directed pre-conditioners (FD-pure, FD+spring, VSR-post at every $\lambda $) halve the median residual relative to raw ($\sim 9.5$--$10.4$k vs.\ $20$k); VSR-intra-soft does not help ($\sim 20$k, $p_v{=}1.0$ vs.\ raw). Among force-directed pre-conditioners, none is significantly better than another (VSR$_{\lambda =8}$ vs.\ FD-pure $p_v{=}0.22$). \textbf {Full legality is $0/24$ under every pre-conditioner}; $\mathbf {0/168}$ method-trials ever reach $v{=}0$. Macros-only HPWL is not comparable post-DREAMPlace (DREAMPlace optimises full-design density+wirelength on its own objective)}{table.caption.52}{}}
