\newlabel{sec:supp-violation-breakdown}{{Q}{17}{Violation error analysis: count vs.\ area vs.\ max overlap (Q3 / S2)}{appendix.Q}{}}
\@writefile{toc}{\contentsline {section}{\numberline {R}Independent classical force-directed legalizer ($24$ trials)}{17}{appendix.R}\protected@file@percent }
\newlabel{sec:supp-classical}{{R}{17}{Independent classical force-directed legalizer ($24$ trials)}{appendix.R}{}}
\@writefile{lot}{\contentsline {table}{\numberline {18}{\ignorespaces Cross-circuit medians. At $\lambda {=}2$ VSR halves both the count and the total overlap area; the max single-pair drops modestly ($431\to 293$). At $\lambda {=}8$ count and area are unchanged within noise (the $\lambda $ knob trades macros-only HPWL, not legality magnitude \S  \ref {sec:downstream_pipeline}). The remaining $\sim 18$k violations are not concentrated in a few hot-spots: area-per-count drops only $3.82\to 3.13$ ($-18\%$), so VSR removes both \emph  {many tiny} overlaps and many average-sized overlaps in roughly equal proportion. This matches the spatial pattern: violators are still spread across the canvas (bbox ratio $\geq 1$), so the residual is structural and not fixable by more aggressive local repair.}}{18}{table.caption.56}\protected@file@percent }
\newlabel{tab:supp-violation-breakdown}{{18}{18}{Cross-circuit medians. At $\lambda {=}2$ VSR halves both the count and the total overlap area; the max single-pair drops modestly ($431\to 293$). At $\lambda {=}8$ count and area are unchanged within noise (the $\lambda $ knob trades macros-only HPWL, not legality magnitude \S \ref {sec:downstream_pipeline}). The remaining $\sim 18$k violations are not concentrated in a few hot-spots: area-per-count drops only $3.82\to 3.13$ ($-18\%$), so VSR removes both \emph {many tiny} overlaps and many average-sized overlaps in roughly equal proportion. This matches the spatial pattern: violators are still spread across the canvas (bbox ratio $\geq 1$), so the residual is structural and not fixable by more aggressive local repair}{table.caption.56}{}}
\@writefile{lot}{\contentsline {table}{\numberline {19}{\ignorespaces Classical force-directed legalizer on the full $24$ trials ($6$ circuits $\times $ $4$ seeds, R4/Q5). Cross-circuit medians: FD-pure $\Delta v{=}{-}54\%/\Delta h{=}{+}144\%$; FD+spring $\Delta v{=}{-}52\%/\Delta h{=}{+}34\%$; VSR-post($\lambda {=}8$) $\Delta v{=}{-}52\%/\Delta h{=}{-}34\%$. Comparable legality cut, $\sim 70$pp better HPWL.}}{18}{table.caption.57}\protected@file@percent }
\newlabel{tab:supp-classical-24}{{19}{18}{Classical force-directed legalizer on the full $24$ trials ($6$ circuits $\times $ $4$ seeds, R4/Q5). Cross-circuit medians: FD-pure $\Delta v{=}{-}54\%/\Delta h{=}{+}144\%$; FD+spring $\Delta v{=}{-}52\%/\Delta h{=}{+}34\%$; VSR-post($\lambda {=}8$) $\Delta v{=}{-}52\%/\Delta h{=}{-}34\%$. Comparable legality cut, $\sim 70$pp better HPWL}{table.caption.57}{}}
