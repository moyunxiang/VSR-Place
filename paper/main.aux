\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Main result: VSR-post strictly dominates}{5}{subsection.4.2}\protected@file@percent }
\newlabel{sec:main_result}{{4.2}{5}{Main result: VSR-post strictly dominates}{subsection.4.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Per-circuit $\Delta v$ (\% violations) and $\Delta h$ (\% HPWL), mean $\pm $std over 4 seeds. Negative is improvement. Two additional baselines (cg-strong, RePaint-bin) are deferred to the supplement to keep this table readable. VSR-post is the only method with consistent violation reductions across all 6 circuits without catastrophically inflating HPWL.}}{5}{table.caption.21}\protected@file@percent }
\newlabel{tab:main}{{1}{5}{Per-circuit $\Delta v$ (\% violations) and $\Delta h$ (\% HPWL), mean $\pm $std over 4 seeds. Negative is improvement. Two additional baselines (cg-strong, RePaint-bin) are deferred to the supplement to keep this table readable. VSR-post is the only method with consistent violation reductions across all 6 circuits without catastrophically inflating HPWL}{table.caption.21}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Per-circuit, per-method comparison (4 seeds each). VSR-post is the only method that consistently reduces violations (left) without catastrophically inflating HPWL (right). CD-std and CD-sched reduce violations less and balloon HPWL by 70--400\%.}}{5}{figure.caption.22}\protected@file@percent }
\newlabel{fig:percircuit}{{2}{5}{Per-circuit, per-method comparison (4 seeds each). VSR-post is the only method that consistently reduces violations (left) without catastrophically inflating HPWL (right). CD-std and CD-sched reduce violations less and balloon HPWL by 70--400\%}{figure.caption.22}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Strict Pareto frontier}{5}{subsection.4.3}\protected@file@percent }
\newlabel{sec:strict_pareto}{{4.3}{5}{Strict Pareto frontier}{subsection.4.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}Statistical significance}{5}{subsection.4.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Number of (circuit, seed) pairs strictly Pareto-improving the raw diffusion draft (\,$\Delta v<0$ AND $\Delta h<0$ jointly) at $\lambda =2$. The complementary $24-12=12$ trials \emph  {not} strictly Pareto-improving include 12 ``non-Pareto'' trials (HPWL grew) and 2 ``weak-violation-cut'' trials on bigblue1 (Pareto-improved on HPWL but $\Delta v > -20\%$); see Appendix D for the full breakdown of the 14 entries flagged in our failure analysis. ChipDiffusion's released legalizers achieve $0/24$ strict-Pareto improvements (every trial inflates HPWL). At $\lambda =8$ VSR-post reaches $18/18$ (\S  \ref {sec:lambda_sweep}).}}{6}{table.caption.23}\protected@file@percent }
\newlabel{tab:strict_pareto}{{2}{6}{Number of (circuit, seed) pairs strictly Pareto-improving the raw diffusion draft (\,$\Delta v<0$ AND $\Delta h<0$ jointly) at $\lambda =2$. The complementary $24-12=12$ trials \emph {not} strictly Pareto-improving include 12 ``non-Pareto'' trials (HPWL grew) and 2 ``weak-violation-cut'' trials on bigblue1 (Pareto-improved on HPWL but $\Delta v > -20\%$); see Appendix D for the full breakdown of the 14 entries flagged in our failure analysis. ChipDiffusion's released legalizers achieve $0/24$ strict-Pareto improvements (every trial inflates HPWL). At $\lambda =8$ VSR-post reaches $18/18$ (\S \ref {sec:lambda_sweep})}{table.caption.23}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Circuit-level paired Wilcoxon, $n=6$ (mean over 4 seeds within each circuit). $^{\star }$: $p<0.05$. VSR-post outperforms both ChipDiffusion legalizers on both metrics; the comparison to classifier-guidance is significant on violations but \emph  {not} on HPWL ($p=0.25$), which we report transparently. The seed-level $n=24$ test (supplement Table~\ref {tab:wilcoxon-seed}) gives the same direction with smaller $p$-values, but treats seeds-within-a-circuit as paired bootstrap draws, not iid samples.}}{6}{table.caption.24}\protected@file@percent }
\newlabel{tab:wilcoxon}{{3}{6}{Circuit-level paired Wilcoxon, $n=6$ (mean over 4 seeds within each circuit). $^{\star }$: $p<0.05$. VSR-post outperforms both ChipDiffusion legalizers on both metrics; the comparison to classifier-guidance is significant on violations but \emph {not} on HPWL ($p=0.25$), which we report transparently. The seed-level $n=24$ test (supplement Table~\ref {tab:wilcoxon-seed}) gives the same direction with smaller $p$-values, but treats seeds-within-a-circuit as paired bootstrap draws, not iid samples}{table.caption.24}{}}
